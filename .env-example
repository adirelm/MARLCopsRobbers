# ============================================================================
# .env-example — Assignment 6 MARL Cops & Robbers (group adrl-001)
# ----------------------------------------------------------------------------
# TRACKED placeholder file. Copy to `.env` (GIT-IGNORED) and fill real values.
# NAMES ONLY here — no real secrets, ever (V3 secrets gate; A1-A5 PII deny-list).
# Real student names/IDs live in players.local.yaml (also git-ignored), NOT here.
#
#   cp .env-example .env   # then fill; .env must be in .gitignore
#
# .gitignore MUST contain:  .env  .env.*  !.env-example  *.pem  *.key
#                           secrets/  results/.report_sent  results/reports/*.real.json
# ============================================================================

# --- MCP bearer tokens (BRIEF §5.3) — Stage 1 localhost StaticTokenVerifier ---
COP_MCP_TOKEN=                 # bearer token the referee/peer uses to call the Cop server
THIEF_MCP_TOKEN=              # bearer token the referee/peer uses to call the Thief server
REFEREE_MCP_TOKEN=           # bearer token the referee presents to both servers
PEER_MCP_TOKEN=              # JWT a server uses to call its peer (cop<->thief, §5.3)

# --- MCP JWT auth (BRIEF §5.3) — Stage 2 cloud JWTVerifier (RS256, revocable) ---
MCP_AUTH_MODE=               # set to `jwt` on the cloud servers; unset/static = localhost
MCP_PUBLIC_KEY=              # RSA public PEM — verifies inbound JWTs (set on servers)
MCP_PRIVATE_KEY=             # RSA private PEM — mints client JWTs (local/CI ONLY)
REVOKED_TOKEN_JTIS=          # comma-separated jti deny-list (fast per-token revoke)

# --- Cloud deploy (BRIEF §6 step 8 / §8 Prefect Horizon) ---
PREFECT_API_KEY=             # Horizon deploy credential — DISTINCT from runtime bearer
COP_PUBLIC_URL=              # e.g. https://adrl-001-cop.fastmcp.app/mcp (Stage-2)
THIEF_PUBLIC_URL=            # e.g. https://adrl-001-thief.fastmcp.app/mcp (Stage-2)
MODEL_PATH=                  # path to the actor-only .pt bundle loaded by the servers

# --- Gmail report (BRIEF §3.5 / §5.5) — smtplib + App Password (default) ---
GMAIL_SENDER=                # the From: Gmail address (App Passwords need 2FA enabled)
GMAIL_APP_PASSWORD=          # 16-char Gmail App Password — single revocable secret
REPORT_RECIPIENT_OVERRIDE=   # optional: override gmail.to for a local dry-run send

# --- Gmail report (fallback) — Gmail API / OAuth (EmailSender Protocol drop-in) ---
GMAIL_OAUTH_CLIENT_ID=       # only if mechanism = gmail_api_oauth
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# --- GUI cloud spectator (BRIEF §5.4 / §5.3 Stage-2) ---
SPECTATOR_TOKEN=             # read-only spectator bearer token (distinct from agent tokens)
