{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MARL Cops & Robbers — BRIEF §3.5 end-of-match report body",
  "type": "object",
  "additionalProperties": false,
  "required": ["group_name", "students", "github_repo", "timezone", "sub_games", "totals"],
  "properties": {
    "group_name": { "type": "string" },
    "students": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "full_name", "id"],
        "properties": {
          "role": { "type": "string" },
          "full_name": { "type": "string" },
          "id": { "type": "string" }
        }
      }
    },
    "github_repo": { "type": "string" },
    "timezone": { "type": "string" },
    "sub_games": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "start", "end", "moves", "winner", "scores"],
        "properties": {
          "id": { "type": "integer" },
          "start": { "type": "string" },
          "end": { "type": "string" },
          "moves": { "type": "integer" },
          "winner": { "type": "string", "enum": ["cop", "thief"] },
          "scores": {
            "type": "object",
            "additionalProperties": false,
            "required": ["cop", "thief"],
            "properties": { "cop": { "type": "integer" }, "thief": { "type": "integer" } }
          }
        }
      }
    },
    "totals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cop", "thief"],
      "properties": { "cop": { "type": "integer" }, "thief": { "type": "integer" } }
    }
  }
}
